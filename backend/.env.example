# MongoDB 数据库连接地址
# 本地默认库名为 campus_lost_found；如果 MongoDB 不在本机，请改成实际连接串
MONGODB_URI=mongodb://127.0.0.1:27017/campus_lost_found

# JWT 签名密钥，必填
# 生产/提交作业前请替换成随机长字符串，可运行：node backend/generate-jwt-secret.js
JWT_SECRET=please_replace_with_a_strong_random_secret

# 后端服务监听端口
# 前端 config.js 里的 baseUrl 端口要和这里保持一致
PORT=3000

# 后端服务监听地址
# 0.0.0.0 表示允许局域网/外部设备访问；只想本机访问可改成 127.0.0.1
HOST=0.0.0.0

# 后端服务的外部访问地址，主要作为部署/联调记录
# 前端实际请求地址请修改 frontend/common/config.js，或运行根目录 set-server-ip.js
BASE_URL=http://localhost:3000

# 允许访问后端的前端来源
# 开发/课程演示可用 *；生产环境建议改成具体前端地址，如 http://localhost:5173
CORS_ORIGIN=*

# 图片识别 AI 配置（可选）
# 用途：发布页上传图片后，识别图片里的物品并生成描述
# 这里要选择“支持图片/视觉/多模态”的模型，不适合填纯文本模型
# 不配置时，图片 AI 识别接口会提示“AI服务未配置”
# 支持 OpenAI 兼容接口；如果使用阿里云百炼 DashScope，也可以改用 DASHSCOPE_API_KEY / DASHSCOPE_API_ENDPOINT
OPENAI_API_KEY=
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# 失物匹配 AI 复核配置（可选）
# 用途：把规则匹配出来的候选记录再交给 AI 判断是否真像同一个物品
# 这里只处理标题、描述、分类、地点、时间等文本字段，选便宜的文本模型即可
# 规则匹配不依赖这里；只有在详情页请求 AI 复核时才需要配置
# 支持 openai 和 anthropic 两种协议；默认推荐 openai
MATCH_AI_PROVIDER=openai
MATCH_AI_API_KEY=
# 可以填完整 /v1/chat/completions 地址，也可以填服务商 OpenAI 兼容 base URL
# 例如 https://api.example.com/openai 会自动补成 https://api.example.com/openai/v1/chat/completions
MATCH_AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
MATCH_AI_MODEL=gpt-4o-mini

# 如果使用 Anthropic 兼容接口，可改成：
# MATCH_AI_PROVIDER=anthropic
# MATCH_AI_API_ENDPOINT=https://api.example.com/anthropic/v1/messages
# MATCH_AI_MODEL=your-low-cost-text-model

# 匹配 AI 返回 token 上限；一般保持默认即可
MATCH_AI_MAX_TOKENS=1200

# 匹配 AI 请求超时时间，单位毫秒
# 低价文本模型响应较慢时可调大，例如 30000 或 45000
MATCH_AI_TIMEOUT_MS=30000
