{
  "name": "campus-lost-found-server",
  "version": "1.0.0",
  "description": "Campus lost and found system backend (Node.js + Express + MongoDB)",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "dev:local": "ENV_FILE=.env.local nodemon app.js",
    "start:local": "ENV_FILE=.env.local node app.js",
    "start:server": "ENV_FILE=.env.server node app.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
